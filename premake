: '
Set up the root environment for the sh, script, and module directories.

Usage:
  . premake
  source premake
'

# Shell Type and Root Directory
if [ $(basename $0) = 'premake' ]
then
  NORM_SRC="$0" && echo "zsh"
elif [ $BASH_SOURCE ]
  then
  NEMD_SRC=${BASH_SOURCE[0]} && echo "POSIX"
else
  x="$(lsof -p $$ -Fn0 | tail -1 | tr -d "\0")" && NEMD_SRC=${x#*n} && echo "dash"
fi
[ ! -f $NORM_SRC ] && echo "Cannot locate the source root" && return 1
export NORM_SRC="$(readlink -f ${NORM_SRC} | xargs dirname)" && echo $NORM_SRC
. $NORM_SRC/sh/norm_func

add_pypath $NORM_SRC/module
add_path $NORM_SRC/driver
add_path $NORM_SRC/sh
add_path $NORM_SRC/gui
